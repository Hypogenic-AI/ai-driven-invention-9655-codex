{"type":"item.started","item":{"id":"item_135","type":"command_execution","command":"/bin/bash -lc \"bash -lc 'source .venv/bin/activate && python - <<\\\"PY\\\"\nfrom pathlib import Path\nfrom pypdf import PdfReader\nimport re, json\n\npapers = {\n\\\"GNoME\\\": \\\"papers/s41586-023-06735-9_gnome_scaling_deep_learning_materials_discovery.pdf\\\",\n\\\"A-Lab\\\": \\\"papers/s41586-023-06734-w_alab_autonomous_laboratory_inorganic_materials.pdf\\\",\n\\\"Matbench Discovery\\\": \\\"papers/2308.14920_matbench_discovery_crystal_stability_benchmark.pdf\\\",\n\\\"OMat24\\\": \\\"papers/2410.12771_omat24_open_materials_dataset_models.pdf\\\",\n\\\"MatterGen\\\": \\\"papers/2312.03687_mattergen_generative_inorganic_materials_design.pdf\\\",\n\\\"LLMatDesign\\\": \\\"papers/2406.13163_llmatdesign_autonomous_materials_discovery_llms.pdf\\\",\n\\\"UMA\\\": \\\"papers/2506.23971_uma_universal_models_for_atoms.pdf\\\",\n\\\"MACE-MP\\\": \\\"papers/2401.00096_mace_mp_atomistic_materials_chemistry_foundation_model.pdf\\\",\n\\\"CHGNet\\\": \\\"papers/2302.14231_chgnet_charge_informed_atomistic_modeling.pdf\\\",\n\\\"M3GNet\\\": \\\"papers/2202.02450_m3gnet_universal_graph_interatomic_potential.pdf\\\",\n\\\"Foundation Perspective\\\": \\\"papers/2503.10538_foundation_models_atomistic_simulation_perspective.pdf\\\",\n\\\"Review 2026\\\": \\\"papers/2606.02507_automated_inverse_materials_design_review.pdf\\\",\n\\\"Diffusion Transformers\\\": \\\"papers/2406.09263_diffusion_transformers_crystal_inverse_design.pdf\\\",\n}\nkeywords = re.compile(r\\\"(dataset|benchmark|baseline|method|model|metric|result|limitation|stability|formation|energy|force|active learning|diffusion|autonomous|DFT|Materials Project|Matbench|Open Materials|OMat|QM9|JARVIS|valid|novel|unique)\\\", re.I)\nfor title, path in papers.items():\n    reader = PdfReader(path)\n    page_texts = []\n    for i, page in enumerate(reader.pages):\n        text = page.extract_text() or \\\"\\\"\n        text = re.sub(r\\\"\\\\s+\\\", \\\" \\\", text).strip()\n        if i < 2 or keywords.search(text):\n            page_texts.append((i+1, text[:1800]))\n    print(\\\"\\\\n===\\\", title, \\\"===\\\")\n    print(\\\"pages\\\", len(reader.pages), \\\"selected\\\", len(page_texts))\n    for page_no, text in page_texts[:8]:\n        print(f\\\"[p{page_no}] {text[:1200]}\\\")\n    if len(page_texts) > 8:\n        print(f\\\"... {len(page_texts)-8} more selected pages\\\")\nPY'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
