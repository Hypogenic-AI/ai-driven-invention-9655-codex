ilename, repo_type=\\\"dataset\\\")\n    dest = omat_dir / filename\n    dest.parent.mkdir(parents=True, exist_ok=True)\n    shutil.copy2(src, dest)\n    print(f\\\"  saved {dest}\\\")\n\n# QM9 molecule atomistic dataset, saved as Arrow for immediate loading.\nprint(\\\"Downloading QM9 via datasets\\\")\nqm9 = load_dataset(\\\"yairschiff/qm9\\\", split=\\\"train\\\")\nqm9.save_to_disk(str(root / \\\"qm9_hf\\\"))\nprint(f\\\"QM9 rows: {len(qm9)}\\\")\nPY'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
